# Staging Environment
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO

# Database (RDS)
DB_HOST=${RDS_ENDPOINT}
DB_PORT=5432
DB_NAME=claims_db
DB_USER=claims_app
DB_PASSWORD=${DB_PASSWORD}
DATABASE_URL=postgresql://claims_app:${DB_PASSWORD}@${RDS_ENDPOINT}:5432/claims_db

# AWS
AWS_DEFAULT_REGION=ap-south-1

# S3
S3_BUCKET=claims-documents-staging
RESULTS_BUCKET=claims-results-staging
MODEL_BUCKET=claims-models-staging

# DynamoDB
CLAIMS_TABLE=claims-metadata-staging
AUDIT_TABLE=claims-audit-staging
FRAUD_SCORES_TABLE=claims-fraud-scores-staging

# SNS
SNS_TOPIC=arn:aws:sns:ap-south-1:${AWS_ACCOUNT_ID}:claims-alerts-staging

# Model
MODEL_KEY=models/fraud/v2.1.0.joblib
MODEL_VERSION=v2.1.0

# Thresholds
FRAUD_THRESHOLD_HIGH=0.8
FRAUD_THRESHOLD_MEDIUM=0.5
FRAUD_AUTO_REJECT_THRESHOLD=0.85
FRAUD_MANUAL_REVIEW_THRESHOLD=0.5
MIN_VALIDATION_SCORE=70.0
MIN_VALIDATION_SCORE_FOR_AUTO=70.0
MAX_RETRY_ATTEMPTS=3

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# SageMaker
SAGEMAKER_ENDPOINT=fraud-detection-staging
