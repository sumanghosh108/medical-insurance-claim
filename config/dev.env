# Development Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=claims_db
DB_USER=postgres
DB_PASSWORD=Admin
DATABASE_URL=postgresql://postgres:Admin@localhost:5432/claims_db

# AWS (LocalStack)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# S3
S3_BUCKET=claims-documents-dev
RESULTS_BUCKET=claims-results-dev
MODEL_BUCKET=claims-models-dev

# DynamoDB
CLAIMS_TABLE=claims-metadata-dev
AUDIT_TABLE=claims-audit-dev
FRAUD_SCORES_TABLE=claims-fraud-scores-dev

# SNS
SNS_TOPIC=arn:aws:sns:us-east-1:000000000000:claims-alerts-dev

# Model
MODEL_KEY=models/fraud/v2.1.0.joblib
MODEL_VERSION=v2.1.0
MODEL_PATH=./ml_models/model/
FEATURE_TRANSFORMER_PATH=./ml_models/models/

# Thresholds
FRAUD_THRESHOLD_HIGH=0.8
FRAUD_THRESHOLD_MEDIUM=0.5
FRAUD_AUTO_REJECT_THRESHOLD=0.85
FRAUD_MANUAL_REVIEW_THRESHOLD=0.5
MIN_VALIDATION_SCORE=70.0
MIN_VALIDATION_SCORE_FOR_AUTO=70.0
MAX_RETRY_ATTEMPTS=3

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Testing
TEST_DATA_PATH=./tests/fixtures/
